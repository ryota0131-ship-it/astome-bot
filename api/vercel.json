{
  "version": 2,
  "functions": {
    "api/webhook.js": {"maxDuration": 30},
    "api/deferred-search.js": {"maxDuration": 30}
  },
  "routes": [
    {"src": "/webhook", "dest": "/api/webhook.js"},
    {
      "src": "/api/calendar-data",
      "dest": "/api/calendar-data.js",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    {"handle": "filesystem"}
  ]
}
